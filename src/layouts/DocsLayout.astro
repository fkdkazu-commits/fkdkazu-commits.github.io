---
interface Props {
  title: string;
  description: string;
  docType: '要件定義書' | '設計書' | 'ドキュメント';
  version?: string;
  date?: string;
}

const { title, description, docType, version = '1.0', date = new Date().toLocaleDateString('ja-JP') } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | AI SEO自動運用ブログシステム</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
    <style>
      body { font-family: 'Noto Sans JP', sans-serif; }
      @media print {
        .no-print { display: none !important; }
        body { font-size: 11pt; }
        h2 { page-break-before: auto; }
      }
    </style>
  </head>
  <body class="bg-gray-50 text-gray-900">

    <!-- Nav -->
    <nav class="no-print bg-white border-b border-gray-200 sticky top-0 z-10">
      <div class="max-w-5xl mx-auto px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href={`${import.meta.env.BASE_URL}docs/`} class="text-sm text-gray-500 hover:text-blue-600">← 資料一覧</a>
          <span class="text-gray-300">|</span>
          <span class="text-sm font-medium text-gray-700">{docType}</span>
        </div>
        <div class="flex items-center gap-4">
          <a href={`${import.meta.env.BASE_URL}docs/requirements/`} class="text-sm text-gray-600 hover:text-blue-600">要件定義書</a>
          <a href={`${import.meta.env.BASE_URL}docs/design/`} class="text-sm text-gray-600 hover:text-blue-600">設計書</a>
          <button onclick="window.print()" class="text-sm bg-blue-600 text-white px-4 py-1.5 rounded hover:bg-blue-700 transition-colors">
            印刷 / PDF保存
          </button>
        </div>
      </div>
    </nav>

    <!-- Document Header -->
    <div class="bg-white border-b border-gray-200 py-10">
      <div class="max-w-5xl mx-auto px-6">
        <div class="flex items-start justify-between">
          <div>
            <p class="text-blue-600 text-sm font-semibold tracking-widest uppercase mb-2">{docType}</p>
            <h1 class="text-3xl font-bold text-gray-900 mb-3">{title}</h1>
            <p class="text-gray-600 max-w-2xl">{description}</p>
          </div>
          <div class="no-print hidden md:block text-right text-sm text-gray-500 space-y-1 ml-8 shrink-0">
            <p>バージョン: <span class="font-medium text-gray-700">v{version}</span></p>
            <p>作成日: <span class="font-medium text-gray-700">{date}</span></p>
            <p>ステータス: <span class="bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-medium text-xs">ドラフト</span></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="max-w-5xl mx-auto px-6 py-10">
      <slot />
    </div>

    <footer class="no-print border-t border-gray-200 py-6 mt-10">
      <div class="max-w-5xl mx-auto px-6 text-center text-sm text-gray-400">
        本資料は提案用ドキュメントです。内容は変更される場合があります。
      </div>
    </footer>
  </body>
</html>
