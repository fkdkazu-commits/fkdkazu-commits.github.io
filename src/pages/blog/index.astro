---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="記事一覧 | AIメディア" description="AI・ChatGPT・業務効率化・SEOに関する実践的な記事一覧です。">
  <nav class="text-sm text-gray-500 mb-6">
    <ol class="flex gap-2">
      <li><a href={import.meta.env.BASE_URL} class="hover:text-blue-600">ホーム</a></li>
      <li>/</li>
      <li class="text-gray-900">記事一覧</li>
    </ol>
  </nav>

  <h1 class="text-3xl font-bold mb-8">記事一覧</h1>

  {posts.length === 0 ? (
    <p class="text-gray-500">記事を準備中です。</p>
  ) : (
    <ul class="space-y-8">
      {posts.map((post) => (
        <li class="border-b border-gray-100 pb-8">
          <a href={`${import.meta.env.BASE_URL}blog/${post.slug}/`} class="group block">
            <p class="text-sm text-gray-500 mb-1">
              {post.data.pubDate.toLocaleDateString('ja-JP')}
            </p>
            <h2 class="text-xl font-semibold group-hover:text-blue-600 transition-colors mb-2">
              {post.data.title}
            </h2>
            <p class="text-gray-600 text-sm line-clamp-2 mb-3">{post.data.description}</p>
            <div class="flex gap-2">
              {post.data.tags.map((tag) => (
                <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded">{tag}</span>
              ))}
            </div>
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
